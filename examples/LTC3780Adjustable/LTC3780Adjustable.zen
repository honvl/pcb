"""
LTC3780-based adjustable buck converter.

Reference design basis:
- LTC3780 datasheet Rev. G typical application
- DC686A LTC3780 evaluation board schematic

Target operating point:
- VIN: 5V source capable of up to 12A
- VOUT: adjustable around 3.3V, nominal trim range about 2.9V to 3.7V
- IOUT: 10A target in buck mode

This is a schematic starting point. Loop compensation, MOSFET/inductor thermals,
capacitor DC bias derating, and transient response still need bench validation.
"""

load("@stdlib/units.zen", "Current", "Voltage")

Resistor = Module("@stdlib/generics/Resistor.zen")
Capacitor = Module("@stdlib/generics/Capacitor.zen")
TerminalBlock = Module("@stdlib/generics/TerminalBlock.zen")

PowerRail = builtin.net_type(
    "PowerRail",
    voltage=Voltage,
    max_current=Current,
)

PowerPath = builtin.net_type(
    "PowerPath",
    max_current=Current,
)

VIN_5V = PowerRail(voltage="5V", max_current="15A")
VOUT_ADJ = PowerRail(voltage="2.9V - 3.7V", max_current="15A")
GND = Ground()

CS = PowerPath(max_current="15A")
SW1 = PowerPath(max_current="15A")
SW2 = PowerPath(max_current="15A")
BOOST1 = Net()
BOOST2 = Net()
TG1_GATE = Net()
BG1_GATE = Net()
TG2_GATE = Net()
BG2_GATE = Net()
INTVCC = Net()
SS = Net()
STBYMD = Net()
ITH = Net()
ITH_RC = Net()
VFB = Net()
VFB_TOP = Net()
PGOOD = Net()

Component(
    name="U1",
    symbol=Symbol(library="./LTC3780EG.kicad_sym"),
    footprint="Package_SO:SSOP-24_5.3x7.2mm_P0.65mm",
    part=Part(
        mpn="LTC3780EG#PBF",
        manufacturer="Analog Devices",
    ),
    pins={
        "PGOOD": PGOOD,
        "SS": SS,
        "SENSE+": CS,
        "SENSE-": GND,
        "ITH": ITH,
        "VOSENSE": VFB,
        "SGND": GND,
        "RUN": VIN_5V,
        "FCB": GND,
        "PLLFLTR": GND,
        "PLLIN": NotConnected(),
        "STBYMD": STBYMD,
        "BOOST1": BOOST1,
        "TG1": TG1_GATE,
        "SW1": SW1,
        "VIN": VIN_5V,
        "EXTVCC": NotConnected(),
        "INTVCC": INTVCC,
        "BG1": BG1_GATE,
        "PGND": CS,
        "BG2": BG2_GATE,
        "SW2": SW2,
        "TG2": TG2_GATE,
        "BOOST2": BOOST2,
    },
)

Component(
    name="Q1",
    symbol=Symbol(library="./PowerNMOS_5pin.kicad_sym"),
    footprint="Package_SO:ONSemi_SO-8FL_488AA",
    part=Part(mpn="NTMFS5C670NLT1G", manufacturer="onsemi"),
    properties={
        "description": "Input-side high-side N-MOSFET",
        "rds_on": "8.8mOhm @ 4.5V",
    },
    pins={
        "G": TG1_GATE,
        "D": VIN_5V,
        "S_1": SW1,
        "S_2": SW1,
        "S_3": SW1,
    },
)

Component(
    name="Q2",
    symbol=Symbol(library="./PowerNMOS_5pin.kicad_sym"),
    footprint="Package_SO:ONSemi_SO-8FL_488AA",
    part=Part(mpn="NTMFS5C670NLT1G", manufacturer="onsemi"),
    properties={
        "description": "Input-side low-side N-MOSFET",
        "rds_on": "8.8mOhm @ 4.5V",
    },
    pins={
        "G": BG1_GATE,
        "D": SW1,
        "S_1": CS,
        "S_2": CS,
        "S_3": CS,
    },
)

Component(
    name="Q3",
    symbol=Symbol(library="./PowerNMOS_5pin.kicad_sym"),
    footprint="Package_SO:ONSemi_SO-8FL_488AA",
    part=Part(mpn="NTMFS5C670NLT1G", manufacturer="onsemi"),
    properties={
        "description": "Output-side low-side N-MOSFET",
        "rds_on": "8.8mOhm @ 4.5V",
    },
    pins={
        "G": BG2_GATE,
        "D": SW2,
        "S_1": CS,
        "S_2": CS,
        "S_3": CS,
    },
)

Component(
    name="Q4",
    symbol=Symbol(library="./PowerNMOS_5pin.kicad_sym"),
    footprint="Package_SO:ONSemi_SO-8FL_488AA",
    part=Part(mpn="NTMFS5C670NLT1G", manufacturer="onsemi"),
    properties={
        "description": "Output-side high-side N-MOSFET",
        "rds_on": "8.8mOhm @ 4.5V",
    },
    pins={
        "G": TG2_GATE,
        "D": VOUT_ADJ,
        "S_1": SW2,
        "S_2": SW2,
        "S_3": SW2,
    },
)

Component(
    name="D1",
    symbol=Symbol(library="@kicad-symbols/Device.kicad_sym", name="D_Schottky"),
    footprint="Diode_SMD:D_SMA",
    part=Part(mpn="B340A-13-F", manufacturer="Diodes Inc."),
    pins={
        "A": CS,
        "K": SW1,
    },
)

Component(
    name="D2",
    symbol=Symbol(library="@kicad-symbols/Device.kicad_sym", name="D_Schottky"),
    footprint="Diode_SMD:D_SMA",
    part=Part(mpn="B340A-13-F", manufacturer="Diodes Inc."),
    pins={
        "A": SW2,
        "K": VOUT_ADJ,
    },
)

Component(
    name="L1",
    symbol=Symbol(library="@kicad-symbols/Device.kicad_sym", name="L"),
    footprint=File("./XAL7070472MEC.kicad_mod"),
    part=Part(mpn="XAL7070-472MEC", manufacturer="Coilcraft"),
    properties={
        "value": "4.7uH",
        "current": "13.6A",
        "isat": "15.2A",
        "dcr": "14.26mOhm typ",
    },
    pins={
        "1": SW1,
        "2": SW2,
    },
)

Component(
    name="RV1",
    symbol=Symbol(library="./TrimPot10k.kicad_sym"),
    footprint="Potentiometer_SMD:Potentiometer_Bourns_TC33X_Vertical",
    part=Part(mpn="TC33X-2-103E", manufacturer="Bourns"),
    properties={
        "value": "10kohm trim",
        "description": "Output voltage adjust trim, wired as a rheostat",
    },
    pins={
        "1": VFB_TOP,
        "2": VFB,
        "3": VFB,
    },
)

TerminalBlock(
    name="JIN",
    pins=2,
    pitch="5.0mm",
    P1=VIN_5V,
    P2=GND,
)

TerminalBlock(
    name="JOUT",
    pins=2,
    pitch="5.0mm",
    P1=VOUT_ADJ,
    P2=GND,
)

Resistor(
    name="RSENSE",
    value="10mOhm 1%",
    package="2512",
    power="2W",
    mpn="PA2512FKF7W0R01E",
    manufacturer="YAGEO",
    P1=CS,
    P2=GND,
)

Resistor(
    name="RFB_FIXED",
