    package="0402",
    mpn="ERJ-2RKF2612X",
    manufacturer="Panasonic Electronic Components",
    P1=VOUT_ADJ,
    P2=VFB_TOP,
)

Resistor(
    name="RFB_BOTTOM",
    value="10kohm 1%",
    package="0402",
    mpn="ERJ-2RKF1002X",
    manufacturer="Panasonic Electronic Components",
    P1=VFB,
    P2=GND,
