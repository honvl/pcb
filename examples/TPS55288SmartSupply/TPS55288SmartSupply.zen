    P1=DRIVE_L,
    P2=Q2_GATE,
)

# UVLO divider: EN/UVLO rising threshold = 1.23V (TPS55288 datasheet), target UVLO ~ 3.3V
# V_TH = 1.23 * (196k + 115k) / 115k = 3.33V
Resistor(
    name="RUVLO_TOP",
    value="196kohm 1%",
    package="0603",
    P1=VIN,
    P2=EN_UVLO,
)

Resistor(
    name="RUVLO_BOTTOM",
    value="115kohm 1%",
    package="0402",
    P1=EN_UVLO,
    P2=GND,
)

Resistor(
    name="RFSW",
    value="49.9kohm 1%",
    package="0402",
    P1=FSW_CFG,
    P2=GND,
)

Resistor(
    name="RMODE",
    value="0ohm",
    package="0402",
    P1=MODE_CFG,
    P2=GND,
)

Resistor(
    name="RILIM",
    value="20kohm 1%",
    package="0402",
    P1=ILIM_CFG,
    P2=GND,
)

Resistor(
