        "SCL": I2C_CTRL.SCL,
        "VS": VDD_3V3,
        "GND": GND,
        "Vbus": VOUT_RAW,  # Bus voltage measured pre-shunt for accurate power calculation
        "Vin-": ISENSE_N,  # Filtered shunt sense, load side
        "Vin+": ISENSE_P,  # Filtered shunt sense, converter side
    },
)

