    mpn="PA2512FKF7T0R005E",
    manufacturer="YAGEO",
    P1=VOUT_RAW,
    P2=VOUT,
)

# INA226 input RC filter: 10Ω series + 100nF differential (CISENSE)
# pole at 1/(2π × 20Ω × 100nF) ≈ 80kHz — well above DC/audio, well below switching frequency
Resistor(
    name="RFILT_ISP",
    value="10ohm 1%",
    package="0402",
    P1=VOUT_RAW,
    P2=ISENSE_P,
)

Resistor(
