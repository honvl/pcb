"""
TPS55288-based smart buck-boost power supply.

This is a more credible replacement for a low-cost LTC3780-style CC/CV module:
- Buck-boost power stage around TI TPS55288
- MCU-managed voltage and current setpoints over I2C
- MCU-managed USB-PD / PPS sink negotiation through STM32 UCPD
- INA226 output telemetry for voltage/current display
- 4-pin header for a common SSD1306 I2C OLED module
- EC11 rotary encoder with pushbutton for the user interface
- Wide-range screw-terminal input plus USB-C PD/PPS input
- Manual source-select switch between the two input sources

Intended operating envelope:
- VIN_MAIN: 3.3V to 28V at the screw terminal
- VIN_USB: 5V to 20V negotiated USB-C PD/PPS input
- VOUT: 0.8V to 20V, software-programmable
- IOUT: software-limited, practical continuous target about 5A to 6A

This is a schematic starting point. It does not include firmware, thermal validation,
or a finished layout.
"""

load("@stdlib/interfaces.zen", "Gpio", "I2c", "NotConnected")
load("@stdlib/units.zen", "Current", "Voltage")

Capacitor = Module("@stdlib/generics/Capacitor.zen")
PinHeader = Module("@stdlib/generics/PinHeader.zen")
Resistor = Module("@stdlib/generics/Resistor.zen")
TerminalBlock = Module("@stdlib/generics/TerminalBlock.zen")

PowerRail = builtin.net_type(
    "PowerRail",
    voltage=Voltage,
    max_current=Current,
)

PowerPath = builtin.net_type(
    "PowerPath",
    max_current=Current,
)

VIN_MAIN = PowerRail(voltage="3.3V - 28V", max_current="6A")
VIN_USB = PowerRail(voltage="5V - 20V", max_current="3A")
VIN_USB_FUSED = PowerRail(voltage="5V - 20V", max_current="3A")
VIN = PowerRail(voltage="3.3V - 28V", max_current="6A")
VOUT_RAW = PowerRail(voltage="0.8V - 20V", max_current="6A")
VOUT = PowerRail(voltage="0.8V - 20V", max_current="6A")
GND = Ground()
VCC_5V = Power(voltage="5V")
VDD_3V3 = Power(voltage="3.3V")
I2C_CTRL = I2c("I2C_CTRL")

SW1 = PowerPath(max_current="6A")
SW2 = PowerPath(max_current="6A")
DRIVE_H = Net()
DRIVE_L = Net()
Q1_GATE = Net()
Q2_GATE = Net()
BOOT1 = Net()
BOOT2 = Net()
EN_UVLO = Net()
MODE_CFG = Net()
FSW_CFG = Net()
DITH_SYNC = Net()
ILIM_CFG = Net()
COMP = Net()
COMP_RC = Net()
ENC_A = Gpio()
ENC_B = Gpio()
ENC_SW = Gpio()
INA_ALERT_N = Gpio()
USB_CC1 = Net()
USB_CC2 = Net()
MAIN_PRESENT = Gpio()
USB_DBCC1 = Net()
USB_DBCC2 = Net()
SWDIO = Gpio()
SWCLK = Gpio()
NRST = Gpio()
SWO = Gpio()
DBG_KEY = Net()
DBG_NC = Net()
ISENSE_P = Net()  # INA226 Vin+ side (after RFILT_ISP filter resistor)
ISENSE_N = Net()  # INA226 Vin- side (after RFILT_ISN filter resistor)

Component(
    name="U1",
    symbol=Symbol(library="./TPS55288RPMR.kicad_sym"),
    footprint=File("./TPS55288RPMR.kicad_mod"),
    part=Part(
        mpn="TPS55288RPMR",
        manufacturer="Texas Instruments",
    ),
    properties={
        "description": "36V, 16A buck-boost converter with digital CV/CC control",
        "lcsc": "C2864583",
    },
    pins={
        "DR1L_1": DRIVE_L,
        "DR1H": DRIVE_H,
        "VIN": VIN,
        "EN_UVLO": EN_UVLO,
        "SCL": I2C_CTRL.SCL,
        "SDA": I2C_CTRL.SDA,
        "DITH_SYNC_1": DITH_SYNC,
        "FSW": FSW_CFG,
        "PGND_1": GND,
        "AGND": GND,
        "VOUT_1": VOUT_RAW,
        "ISP": VOUT_RAW,
        "ISN_1": VOUT,
        "FB_INT": NotConnected(),
        "MODE": MODE_CFG,
        "CDC": NotConnected(),
        "ILIM": ILIM_CFG,
        "COMP": COMP,
        "VCC_1": VCC_5V,
        "BOOT2": BOOT2,
        "SW2_1": SW2,
        "BOOT1": BOOT1,
        "SW1": SW1,
        "PGND_2": GND,
        "SW2_2": SW2,
        "VOUT_2": VOUT_RAW,
        "DR1L_2": DRIVE_L,
        "DITH_SYNC_2": DITH_SYNC,
        "ISN_2": VOUT,
        "VCC_2": VCC_5V,
    },
)

