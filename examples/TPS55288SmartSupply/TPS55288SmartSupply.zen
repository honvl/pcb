    footprint="Package_SO:VSSOP-10_3x3mm_P0.5mm",
    part=Part(
        mpn="INA226AIDGSR",
        manufacturer="Texas Instruments",
    ),
    properties={
        "description": "Output voltage/current telemetry",
        "lcsc": "C49851",
    },
    pins={
        "A1": GND,
        "A0": GND,
        "~{Alert}": INA_ALERT_N,
